# MySQL (same database as main app — must already have users, product_categories, etc.)
# With docker-compose.yml: use port 3307 on host (see MYSQL_HOST_PORT) unless you changed it.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
# If password contains @ : / ? # etc., keep it as-is here — the app URL-encodes it for SQLAlchemy.
MYSQL_PASSWORD=rootpass
MYSQL_DATABASE=exp

# docker-compose env (optional overrides when running: docker compose up -d)
# MYSQL_ROOT_PASSWORD=rootpass
# MYSQL_HOST_PORT=3307
# REDIS_HOST_PORT=6379

# Redis (docker compose: redis://127.0.0.1:6379/0)
REDIS_URL=redis://127.0.0.1:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8088

# CORS: comma-separated frontend origins (required for Vite on :5173). Do not use * with credentials.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ranking weights (tune for product; higher = more influence)
WEIGHT_PROFILE_VIEWS=0.85
WEIGHT_CATEGORY_RELEVANCE=0.75
WEIGHT_ACCEPTANCE=0.55
WEIGHT_RATING=0.65
WEIGHT_AVAILABILITY=0.35
WEIGHT_PRICE_INVERSE=0.25
WEIGHT_BOOKINGS_24H=0.45
WEIGHT_CONVERSION=0.4
WEIGHT_PERSONALIZATION=0.5
WEIGHT_AVAILABILITY_SIGNAL=0.35
